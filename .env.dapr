# Service Configuration
SERVICE_NAME=chat-service
VERSION=1.0.0
PORT=8013
HOST=0.0.0.0
NODE_ENV=development

# Logging
LOG_LEVEL=debug
LOG_FORMAT=console
LOG_TO_CONSOLE=true
LOG_TO_FILE=false

# Service Invocation Mode
SERVICE_INVOCATION_MODE=dapr

# Dapr Configuration
DAPR_HOST=localhost
DAPR_HTTP_PORT=3513
DAPR_GRPC_PORT=50013
DAPR_APP_ID=chat-service

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Service App IDs (for Dapr service invocation)
PRODUCT_SERVICE_APP_ID=product-service
ORDER_SERVICE_APP_ID=order-service

# =============================================================================
# OpenTelemetry Tracing Configuration
# =============================================================================

# Option 1: Zipkin (Local Development)
OTEL_TRACES_EXPORTER=zipkin
OTEL_EXPORTER_ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans

# Option 2: OTLP (OpenTelemetry Collector)
# OTEL_TRACES_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Service name for tracing
OTEL_SERVICE_NAME=chat-service
